# Postgres connection string (Supabase or any Postgres-compatible host).
# Used by src/db and drizzle.config.ts.
DATABASE_URL=postgresql://user:password@host:5432/database

# Secret used to HMAC-sign session cookies (src/lib/auth.server.ts).
# Generate a real value before deploying, e.g.: openssl rand -base64 32
SESSION_SECRET=change-me-before-production

# Optional — used only by `npm run db:seed` to bootstrap the first admin
# account. SEED_ADMIN_PASSWORD may be omitted; a random one is generated and
# printed once if so.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Google OAuth (patient sign-in only — src/routes/auth/google.ts). Create an
# OAuth client at https://console.cloud.google.com/apis/credentials and add
# "<your-app-origin>/auth/google/callback" as an authorized redirect URI
# (e.g. http://localhost:3000/auth/google/callback in dev).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (src/lib/email.server.ts) — sends signup-verification OTP codes and
# password-reset links. Create an API key at https://resend.com/api-keys.
RESEND_API_KEY=
# Optional. Defaults to Resend's shared sandbox sender (onboarding@resend.dev),
# which only works in dev/testing. Set to a verified sending address on your
# own domain before deploying, e.g. "Mindcarter <noreply@yourdomain.com>".
EMAIL_FROM=

# Optional. Used as a fallback base URL for password-reset links only when
# the incoming request has no Origin header (rare — most requests from a
# browser form submission include one). Defaults to http://localhost:3000.
APP_ORIGIN=
